{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**/*.js",
			"**/*.ts",
			"**/*.mjs",
			"**/*.json",
			"!!**/node_modules",
			"!!themes/PaperMod",
			"!!themes/bryan-chasko-theme/PaperMod",
			"!!themes/bryan-chasko-theme/layouts",
			"!!infrastructure/*.json",
			"!!themes/bryan-chasko-theme/assets/js/fuse.basic.min.js",
			"!!themes/bryan-chasko-theme/assets/js/notes-tilt.min.js",
			"!!public"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noImportantStyles": "off"
			},
			"suspicious": {
				"useIterableCallbackReturn": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
